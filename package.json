{
  "name": "deprecated-finder",
  "displayName": "Deprecated Finder",
  "description": "Find @deprecated symbols across your workspace and apply vendor-suggested replacements with one click.",
  "version": "1.0.1",
  "publisher": "RafaelVieira1720",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/RafaelHDSV/Deprecated-Finder"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "deprecated",
    "jsdoc",
    "typescript",
    "javascript",
    "refactor",
    "migration",
    "codemod",
    "replace",
    "import",
    "react",
    "antd"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "deprecatedFinder.scan",
        "title": "Deprecated Finder: Scan workspace",
        "category": "Deprecated Finder"
      },
      {
        "command": "deprecatedFinder.openPanel",
        "title": "Deprecated Finder: Open panel",
        "category": "Deprecated Finder"
      },
      {
        "command": "deprecatedFinder.fixAll",
        "title": "Deprecated Finder: Fix all",
        "category": "Deprecated Finder"
      },
      {
        "command": "deprecatedFinder.fixItem",
        "title": "Deprecated Finder: Fix item",
        "category": "Deprecated Finder"
      },
      {
        "command": "deprecatedFinder.openFile",
        "title": "Deprecated Finder: Open file at line",
        "category": "Deprecated Finder"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "deprecatedFinder.fixItem",
          "when": "false"
        },
        {
          "command": "deprecatedFinder.openFile",
          "when": "false"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deprecatedFinder",
          "title": "Deprecated Finder",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "deprecatedFinder": [
        {
          "id": "deprecatedFinder.view",
          "name": "Deprecated Items",
          "type": "webview",
          "icon": "media/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Deprecated Finder",
      "properties": {
        "deprecatedFinder.showScanSummary": {
          "type": "string",
          "default": "whenIssuesFound",
          "enum": [
            "always",
            "whenIssuesFound",
            "never"
          ],
          "enumDescriptions": [
            "Show an information notification after every workspace scan that found source files.",
            "Show that notification only when at least one deprecated usage was found.",
            "Never show the post-scan count notification. The «no source files in workspace» notice still appears when no files match."
          ],
          "description": "When to show the toast summarizing how many deprecated usages were found after a full workspace scan. The empty-workspace notice is always shown."
        },
        "deprecatedFinder.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Append detailed scan lines (per tsconfig group, per-file counts) to the Deprecated Finder output channel (View → Output → Deprecated Finder)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint",
    "watch": "tsc -watch -p ./",
    "icon:rasterize": "node scripts/rasterize-icon.cjs"
  },
  "dependencies": {
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.100.0",
    "eslint": "^9.13.0",
    "sharp": "^0.33.5",
    "typescript-eslint": "^8.26.0"
  }
}
