{
  "name": "deprecated-finder",
  "displayName": "deprecated-finder",
  "description": "A VS Code extension sample that finds deprecated API usages in the workspace.",
  "version": "0.0.1",
  "publisher": "vscode-samples",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Microsoft/vscode-extension-samples"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deprecatedFinder.open",
        "title": "Deprecated Finder: Open"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deprecatedFinder",
          "title": "Deprecated Finder",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "deprecatedFinder": [
        {
          "id": "deprecatedFinder.view",
          "name": "Deprecated Items",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "eslint": "^9.13.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
